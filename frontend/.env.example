# -----------------------------------------------------------------------------
# Meri Samaj - Frontend Environment Variables Template
# Copy this file to '.env' and adjust the values as needed.
# -----------------------------------------------------------------------------

# API Endpoint URL (pointing to backend gateway /api/v1)
# Development Default:
VITE_API_URL=http://localhost:5001/api/v1
# Production (Render Deployed Backend):
# VITE_API_URL=https://merisamaj.onrender.com/api/v1

# Client URL (Self-address of the frontend application)
# Development Default:
VITE_CLIENT_URL=http://localhost:5173
# Production (Main Domain):
# VITE_CLIENT_URL=https://meri-samaj-two.vercel.app
