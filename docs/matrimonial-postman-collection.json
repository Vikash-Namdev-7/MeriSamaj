{
  "info": {
    "name": "Meri Samaj - Matrimonial Module",
    "_postman_id": "merisamaj-matrimonial-v1",
    "description": "Complete API collection for the Matrimonial Module of Meri Samaj. All endpoints are under /api/v1. Include Authorization header: Bearer <JWT_TOKEN>.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL",  "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "TOKEN",     "value": "<your_jwt_token>",             "type": "string" },
    { "key": "PROFILE_ID","value": "<matrimonial_profile_id>",     "type": "string" },
    { "key": "INTEREST_ID","value": "<interest_id>",               "type": "string" },
    { "key": "PLAN_ID",   "value": "<subscription_plan_id>",       "type": "string" },
    { "key": "NOTIF_ID",  "value": "<notification_id>",            "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{TOKEN}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": { "method": "POST", "url": "{{BASE_URL}}/auth/register",
            "body": { "mode": "raw", "raw": "{\"name\":\"Test User\",\"mobile\":\"9999999999\",\"password\":\"Password@123\",\"communityId\":\"COMMUNITY_ID\"}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Login",
          "request": { "method": "POST", "url": "{{BASE_URL}}/auth/login",
            "body": { "mode": "raw", "raw": "{\"mobile\":\"9999999999\",\"password\":\"Password@123\"}", "options": { "raw": { "language": "json" } } }
          }
        }
      ]
    },
    {
      "name": "Member - Profile",
      "item": [
        { "name": "Create Profile",   "request": { "method": "POST", "url": "{{BASE_URL}}/member/matrimonial/profile", "body": { "mode": "raw", "raw": "{\"personal\":{\"fullName\":\"Rahul Sharma\",\"gender\":\"male\",\"dateOfBirth\":\"1995-01-01\",\"height\":175,\"maritalStatus\":\"never_married\",\"community\":\"Agrawal\",\"religion\":\"Hindu\"},\"education\":{\"highestQualification\":\"B.Tech\",\"profession\":\"Software Engineer\"},\"location\":{\"city\":\"Indore\",\"state\":\"Madhya Pradesh\",\"country\":\"India\"},\"privacy\":{\"visibility\":\"community\"}}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Get My Profile",   "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/profile/me" } },
        { "name": "Update Profile",   "request": { "method": "PUT",  "url": "{{BASE_URL}}/member/matrimonial/profile", "body": { "mode": "raw", "raw": "{\"about\":{\"biography\":\"A simple family-oriented person.\"}}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Get User Profile", "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/profile/{{PROFILE_ID}}" } },
        { "name": "Search Profiles",  "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/profile/search?gender=female&minAge=22&maxAge=30&city=Indore&page=1&limit=10" } },
        { "name": "Delete Profile",   "request": { "method": "DELETE","url": "{{BASE_URL}}/member/matrimonial/profile" } }
      ]
    },
    {
      "name": "Member - Photos",
      "item": [
        { "name": "Upload Photos",      "request": { "method": "POST", "url": "{{BASE_URL}}/member/matrimonial/profile/photos/upload", "body": { "mode": "formdata", "formdata": [{ "key": "photos", "type": "file", "src": "" }] } } },
        { "name": "Get All Photos",     "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/profile/photos/all" } },
        { "name": "Set Primary Photo",  "request": { "method": "PUT",  "url": "{{BASE_URL}}/member/matrimonial/profile/photos/PHOTO_ID/primary" } },
        { "name": "Delete Photo",       "request": { "method": "DELETE","url": "{{BASE_URL}}/member/matrimonial/profile/photos/PHOTO_ID" } }
      ]
    },
    {
      "name": "Member - Interests",
      "item": [
        { "name": "Send Interest",      "request": { "method": "POST", "url": "{{BASE_URL}}/member/matrimonial/interests/send", "body": { "mode": "raw", "raw": "{\"profileId\":\"{{PROFILE_ID}}\",\"message\":\"Hi, I am interested in connecting.\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Accept Interest",    "request": { "method": "POST", "url": "{{BASE_URL}}/member/matrimonial/interests/accept/{{INTEREST_ID}}" } },
        { "name": "Decline Interest",   "request": { "method": "POST", "url": "{{BASE_URL}}/member/matrimonial/interests/decline/{{INTEREST_ID}}" } },
        { "name": "Withdraw Interest",  "request": { "method": "DELETE","url": "{{BASE_URL}}/member/matrimonial/interests/{{INTEREST_ID}}" } },
        { "name": "Received Interests", "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/interests/received?page=1&limit=10" } },
        { "name": "Sent Interests",     "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/interests/sent?page=1&limit=10" } },
        { "name": "Accepted Interests", "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/interests/accepted" } }
      ]
    },
    {
      "name": "Member - Subscription",
      "item": [
        { "name": "List Plans",          "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/subscription/plans" } },
        { "name": "Get My Subscription", "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/subscription/me" } },
        { "name": "Get History",         "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/subscription/history" } },
        { "name": "Initiate Purchase",   "request": { "method": "POST", "url": "{{BASE_URL}}/member/matrimonial/subscription/purchase", "body": { "mode": "raw", "raw": "{\"planId\":\"{{PLAN_ID}}\",\"gateway\":\"razorpay\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Verify & Activate",   "request": { "method": "POST", "url": "{{BASE_URL}}/member/matrimonial/subscription/verify", "body": { "mode": "raw", "raw": "{\"planId\":\"{{PLAN_ID}}\",\"simulatedPayment\":true}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Cancel Subscription", "request": { "method": "POST", "url": "{{BASE_URL}}/member/matrimonial/subscription/cancel", "body": { "mode": "raw", "raw": "{\"reason\":\"Not needed anymore\"}", "options": { "raw": { "language": "json" } } } } }
      ]
    },
    {
      "name": "Member - Shortlist",
      "item": [
        { "name": "Get Shortlist",   "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/shortlist" } },
        { "name": "Add to Shortlist","request": { "method": "POST", "url": "{{BASE_URL}}/member/matrimonial/shortlist/{{PROFILE_ID}}" } },
        { "name": "Update Notes",    "request": { "method": "PUT",  "url": "{{BASE_URL}}/member/matrimonial/shortlist/{{PROFILE_ID}}", "body": { "mode": "raw", "raw": "{\"notes\":\"Good match potential\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Remove Shortlist","request": { "method": "DELETE","url": "{{BASE_URL}}/member/matrimonial/shortlist/{{PROFILE_ID}}" } }
      ]
    },
    {
      "name": "Member - Chat",
      "item": [
        { "name": "Get Conversations", "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/chat/conversations" } },
        { "name": "Get Messages",      "request": { "method": "GET",  "url": "{{BASE_URL}}/member/matrimonial/chat/{{PROFILE_ID}}/messages?page=1&limit=50" } },
        { "name": "Send Message",      "request": { "method": "POST", "url": "{{BASE_URL}}/member/matrimonial/chat/{{PROFILE_ID}}/messages", "body": { "mode": "raw", "raw": "{\"content\":\"Hello! Nice to connect.\",\"type\":\"text\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Delete Message",    "request": { "method": "DELETE","url": "{{BASE_URL}}/member/matrimonial/chat/messages/MESSAGE_ID" } },
        { "name": "Mark Read",         "request": { "method": "PUT",  "url": "{{BASE_URL}}/member/matrimonial/chat/{{PROFILE_ID}}/read" } }
      ]
    },
    {
      "name": "Member - Block & Report",
      "item": [
        { "name": "Block User",   "request": { "method": "POST",  "url": "{{BASE_URL}}/member/matrimonial/block", "body": { "mode": "raw", "raw": "{\"blockedUserId\":\"{{PROFILE_ID}}\",\"reason\":\"Spam\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Unblock User", "request": { "method": "DELETE","url": "{{BASE_URL}}/member/matrimonial/block/{{PROFILE_ID}}" } },
        { "name": "Report Profile","request": { "method": "POST",  "url": "{{BASE_URL}}/member/matrimonial/report", "body": { "mode": "raw", "raw": "{\"reportedProfileId\":\"{{PROFILE_ID}}\",\"reason\":\"Fake profile\",\"description\":\"Profile seems fake.\",\"severity\":\"medium\"}", "options": { "raw": { "language": "json" } } } } }
      ]
    },
    {
      "name": "Member - Notifications",
      "item": [
        { "name": "Get All",       "request": { "method": "GET",   "url": "{{BASE_URL}}/member/notifications?limit=20&page=1" } },
        { "name": "Unread Count",  "request": { "method": "GET",   "url": "{{BASE_URL}}/member/notifications/unread" } },
        { "name": "Mark Read",     "request": { "method": "PUT",   "url": "{{BASE_URL}}/member/notifications/{{NOTIF_ID}}/read" } },
        { "name": "Mark All Read", "request": { "method": "PUT",   "url": "{{BASE_URL}}/member/notifications/read-all", "body": { "mode": "raw", "raw": "{\"module\":\"matrimonial\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Delete One",    "request": { "method": "DELETE","url": "{{BASE_URL}}/member/notifications/{{NOTIF_ID}}" } },
        { "name": "Clear All",     "request": { "method": "DELETE","url": "{{BASE_URL}}/member/notifications" } }
      ]
    },
    {
      "name": "Admin - Matrimonial",
      "item": [
        { "name": "Dashboard Stats",    "request": { "method": "GET",  "url": "{{BASE_URL}}/admin/matrimonial/stats" } },
        { "name": "Analytics (30d)",    "request": { "method": "GET",  "url": "{{BASE_URL}}/admin/matrimonial/analytics?days=30" } },
        { "name": "All Profiles",       "request": { "method": "GET",  "url": "{{BASE_URL}}/admin/matrimonial/profiles?page=1&limit=20&verificationStatus=pending" } },
        { "name": "Verify Profile",     "request": { "method": "PUT",  "url": "{{BASE_URL}}/admin/matrimonial/profiles/{{PROFILE_ID}}/verify", "body": { "mode": "raw", "raw": "{\"status\":\"verified\",\"adminNote\":\"Documents look good\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Pending Photos",     "request": { "method": "GET",  "url": "{{BASE_URL}}/admin/matrimonial/photos/pending" } },
        { "name": "Moderate Photo",     "request": { "method": "PUT",  "url": "{{BASE_URL}}/admin/matrimonial/photos/PROFILE_ID/PHOTO_ID", "body": { "mode": "raw", "raw": "{\"action\":\"approve\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "All Reports",        "request": { "method": "GET",  "url": "{{BASE_URL}}/admin/matrimonial/reports?status=pending" } },
        { "name": "Action Report",      "request": { "method": "PUT",  "url": "{{BASE_URL}}/admin/matrimonial/reports/REPORT_ID", "body": { "mode": "raw", "raw": "{\"status\":\"action_taken\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "List Plans",         "request": { "method": "GET",  "url": "{{BASE_URL}}/admin/matrimonial/plans" } },
        { "name": "Create Plan",        "request": { "method": "POST", "url": "{{BASE_URL}}/admin/matrimonial/plans", "body": { "mode": "raw", "raw": "{\"name\":\"Gold\",\"price\":999,\"originalPrice\":1499,\"durationInDays\":90,\"features\":{\"interestsPerDay\":20,\"photoUploadLimit\":6,\"contactsPerMonth\":30,\"canChat\":true,\"profileBoost\":false}}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Update Plan",        "request": { "method": "PUT",  "url": "{{BASE_URL}}/admin/matrimonial/plans/{{PLAN_ID}}", "body": { "mode": "raw", "raw": "{\"price\":799}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Delete Plan",        "request": { "method": "DELETE","url": "{{BASE_URL}}/admin/matrimonial/plans/{{PLAN_ID}}" } },
        { "name": "Grant Subscription", "request": { "method": "POST", "url": "{{BASE_URL}}/admin/matrimonial/plans/grant", "body": { "mode": "raw", "raw": "{\"userId\":\"USER_ID\",\"planId\":\"{{PLAN_ID}}\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Get Settings",       "request": { "method": "GET",  "url": "{{BASE_URL}}/admin/matrimonial/settings" } },
        { "name": "Update Settings",    "request": { "method": "PUT",  "url": "{{BASE_URL}}/admin/matrimonial/settings", "body": { "mode": "raw", "raw": "{\"freeInterestLimit\":3,\"maxPhotoUpload\":6}", "options": { "raw": { "language": "json" } } } } }
      ]
    },
    {
      "name": "Head - Matrimonial",
      "item": [
        { "name": "Community Stats",    "request": { "method": "GET", "url": "{{BASE_URL}}/head/matrimonial/stats" } },
        { "name": "Community Profiles", "request": { "method": "GET", "url": "{{BASE_URL}}/head/matrimonial/profiles?page=1&limit=20" } },
        { "name": "Verify Profile",     "request": { "method": "PUT", "url": "{{BASE_URL}}/head/matrimonial/profiles/{{PROFILE_ID}}/verify", "body": { "mode": "raw", "raw": "{\"status\":\"verified\"}", "options": { "raw": { "language": "json" } } } } },
        { "name": "Community Reports",  "request": { "method": "GET", "url": "{{BASE_URL}}/head/matrimonial/reports" } },
        { "name": "Resolve Report",     "request": { "method": "PUT", "url": "{{BASE_URL}}/head/matrimonial/reports/REPORT_ID", "body": { "mode": "raw", "raw": "{\"status\":\"resolved\",\"notes\":\"Addressed\"}", "options": { "raw": { "language": "json" } } } } }
      ]
    }
  ]
}
