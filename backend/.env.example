# Server Configurations
PORT=5001
NODE_ENV=development

# Database Configurations
MONGO_URI=mongodb://localhost:27017/merisamaj

# Authentication Configurations
JWT_SECRET=merisamajsecretkey_change_me_in_production
JWT_EXPIRES_IN=30d

# Cloudinary Service Configurations
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Allowed Frontend Client URLs (comma-separated for CORS setup)
CLIENT_URL=https://meri-samaj-two.vercel.app,http://localhost:5173
